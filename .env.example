APP_MODE=server
SERVER_ADDRESS=0.0.0.0:5550

API_KEY=my_super_secret_key

SYNC_BASE_DIR=./synced

# Local sync entries can be files, folders, or glob patterns. You can use commas or a multiline quoted block.
# Prefix an entry with [RW] to allow client writes; otherwise it is server-to-client only.
# A directory entry expands recursively. Use '->' or '||' to map a server root to a local root.
SYNC_FILES="
[RW] ./local/devs_whitelist
./local/shared/*.txt -> ./synced/shared
"

POLL_INTERVAL=10s

USE_TLS=true
TLS_CERT=cert.pem
TLS_KEY=key.pem